{
  "id": "openclaw-lark-project",
  "name": "Lark Project",
  "version": "0.1.0",
  "description": "Manage Feishu Project work items via configurable credentials.",
  "entry": "./src/index.ts",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["pluginId", "pluginSecret", "userKey"],
    "properties": {
      "pluginId": {
        "type": "string",
        "minLength": 1,
        "title": "Plugin ID"
      },
      "pluginSecret": {
        "type": "string",
        "minLength": 1,
        "title": "Plugin Secret"
      },
      "userKey": {
        "type": "string",
        "minLength": 1,
        "title": "User Key"
      }
    }
  },
  "uiHints": {
    "pluginId": {
      "label": "Plugin ID",
      "placeholder": "例如: cli_xxx"
    },
    "pluginSecret": {
      "label": "Plugin Secret",
      "placeholder": "输入插件密钥",
      "sensitive": true
    },
    "userKey": {
      "label": "User Key",
      "placeholder": "例如: ou_xxx 或 user_xxx"
    }
  }
}
